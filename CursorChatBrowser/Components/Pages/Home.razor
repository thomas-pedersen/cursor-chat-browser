@page "/"
@rendermode InteractiveServer
@inject WorkspaceService WorkspaceSvc

<PageTitle>Cursor Chat Browser</PageTitle>

<div>
    <h1 class="text-4xl font-bold mb-4">Projects</h1>
    <p class="text-muted-foreground mb-8">
        Browse your Cursor chat conversations by project. Click on a project to view its conversations.
    </p>

    @if (_loading)
    {
        <div class="flex items-center justify-center py-12">
            <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-primary"></div>
            <span class="ml-3 text-muted-foreground">Loading projects...</span>
        </div>
    }
    else
    {
        var withConversations = _projects.Where(p => p.ConversationCount > 0).ToList();
        var withoutConversations = _projects.Where(p => p.ConversationCount == 0).ToList();

        @if (withConversations.Any())
        {
            <div class="rounded-lg border border-border bg-card mb-8">
                <div class="p-6 border-b border-border">
                    <h2 class="text-xl font-semibold">Projects with Conversations</h2>
                    <p class="text-sm text-muted-foreground">@withConversations.Count project@(withConversations.Count != 1 ? "s" : "") with chat history</p>
                </div>
                <div class="p-0">
                    <table class="w-full">
                        <thead>
                            <tr class="border-b border-border text-left">
                                <th class="p-3 text-sm font-medium text-muted-foreground">Project</th>
                                <th class="p-3 text-sm font-medium text-muted-foreground">Conversations</th>
                                <th class="p-3 text-sm font-medium text-muted-foreground">Last Modified</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in withConversations)
                            {
                                <tr class="border-b border-border hover:bg-accent/50 transition-colors">
                                    <td class="p-3">
                                        <a href="/workspace/@p.Id" class="text-blue-500 hover:underline font-medium" title="@p.Path">@p.Name</a>
                                    </td>
                                    <td class="p-3">
                                        <span class="text-green-500 font-medium">@p.ConversationCount conversation@(p.ConversationCount != 1 ? "s" : "")</span>
                                    </td>
                                    <td class="p-3 text-muted-foreground">@p.LastModified.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        @if (withoutConversations.Any())
        {
            <div class="rounded-lg border border-border bg-card">
                <div class="p-6 border-b border-border">
                    <h2 class="text-xl font-semibold">Projects without Conversations</h2>
                    <p class="text-sm text-muted-foreground">@withoutConversations.Count project@(withoutConversations.Count != 1 ? "s" : "") with no chat history found</p>
                </div>
                <div class="p-4">
                    <div class="p-4 mb-4 rounded-md border border-border bg-muted/50 text-sm text-muted-foreground">
                        These projects may appear empty due to folder relocation, Cursor updates, or conversations being stored in a different location.
                    </div>
                    <table class="w-full">
                        <thead>
                            <tr class="border-b border-border text-left">
                                <th class="p-3 text-sm font-medium text-muted-foreground">Project</th>
                                <th class="p-3 text-sm font-medium text-muted-foreground">Conversations</th>
                                <th class="p-3 text-sm font-medium text-muted-foreground">Last Modified</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in withoutConversations)
                            {
                                <tr class="border-b border-border hover:bg-accent/50 transition-colors">
                                    <td class="p-3">
                                        <a href="/workspace/@p.Id" class="text-blue-500 hover:underline font-medium" title="@p.Path">@p.Name</a>
                                    </td>
                                    <td class="p-3 text-muted-foreground">0</td>
                                    <td class="p-3 text-muted-foreground">@p.LastModified.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        @if (!_projects.Any())
        {
            <div class="rounded-lg border border-border bg-card p-6 text-center">
                <h2 class="text-xl font-semibold mb-2">No Projects Found</h2>
                <p class="text-muted-foreground mb-4">No Cursor workspace projects were found in the configured location.</p>
                <a href="/config" class="text-blue-500 hover:underline">Check configuration</a>
            </div>
        }
    }
</div>

@code {
    private List<Project> _projects = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _projects = await WorkspaceSvc.GetProjectsAsync();
        _loading = false;
    }
}

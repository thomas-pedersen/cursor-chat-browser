@inject SearchService SearchSvc
@inject NavigationManager Nav
@inject IJSRuntime JS

<button @onclick="Open"
        class="flex items-center gap-2 px-3 py-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors rounded-lg border border-input bg-background hover:bg-accent">
    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
    <span class="hidden sm:inline-block">Search all projects...</span>
    <kbd class="hidden md:inline-flex h-5 items-center gap-1 rounded border bg-muted px-1.5 font-mono text-[10px] font-medium text-muted-foreground">
        <span class="text-xs">Ctrl</span>K
    </kbd>
</button>

@if (_open)
{
    <div class="fixed inset-0 z-50 bg-black/50" @onclick="Close">
        <div class="fixed left-1/2 top-1/4 -translate-x-1/2 w-full max-w-2xl bg-card border border-border rounded-lg shadow-xl overflow-hidden"
             @onclick:stopPropagation="true">

            <div class="flex items-center border-b border-border px-4">
                <svg class="h-5 w-5 text-muted-foreground shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                <input id="global-search-input" type="text" placeholder="Search across all projects..."
                       class="flex-1 bg-transparent px-3 py-4 text-base outline-none border-0 text-foreground"
                       @bind="_query" @bind:event="oninput" @bind:after="OnQueryChanged" @onkeydown="OnKeyDown" />
                @if (_loading)
                {
                    <div class="h-4 w-4 animate-spin rounded-full border-2 border-primary border-t-transparent"></div>
                }
            </div>

            <div class="flex gap-1 px-4 py-2 border-b border-border bg-muted/30">
                @foreach (var f in new[] { "all", "chat", "composer" })
                {
                    var label = f == "all" ? "All" : f == "chat" ? "Ask Logs" : "Agent Logs";
                    var active = _filter == f;
                    <button @onclick="() => SetFilter(f)"
                            class="@($"px-3 py-1 text-xs font-medium rounded-md transition-colors {(active ? "bg-primary text-primary-foreground" : "text-muted-foreground hover:text-foreground hover:bg-muted")}")">
                        @label
                    </button>
                }
            </div>

            <div class="max-h-[400px] overflow-y-auto">
                @if (!string.IsNullOrEmpty(_query) && _results.Count == 0 && !_loading)
                {
                    <div class="py-12 text-center text-muted-foreground">No results found for "@_query"</div>
                }
                else if (string.IsNullOrEmpty(_query))
                {
                    <div class="py-12 text-center text-muted-foreground">Start typing to search</div>
                }
                else
                {
                    <div class="py-2">
                        <div class="px-4 py-1.5 text-xs font-medium text-muted-foreground">@_results.Count result@(_results.Count != 1 ? "s" : "") found</div>
                        @for (var i = 0; i < _results.Count; i++)
                        {
                            var idx = i;
                            var r = _results[i];
                            <button @onclick="() => NavigateTo(r)"
                                    class="@($"w-full flex items-start gap-3 px-4 py-3 text-left transition-colors {(idx == _selectedIndex ? "bg-accent" : "hover:bg-muted/50")}")">
                                <div class="@($"shrink-0 mt-0.5 p-2 rounded-lg {(r.Type == "chat" ? "bg-blue-500/10 text-blue-500" : "bg-purple-500/10 text-purple-500")}")">
                                    @if (r.Type == "chat")
                                    {
                                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                                    }
                                    else
                                    {
                                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
                                    }
                                </div>
                                <div class="flex-1 min-w-0">
                                    <div class="flex items-center gap-2 mb-1">
                                        <span class="font-medium truncate">@r.ChatTitle</span>
                                        <span class="@($"shrink-0 text-[10px] px-1.5 py-0 rounded-full border {(r.Type == "chat" ? "bg-primary text-primary-foreground" : "bg-secondary text-secondary-foreground")}")">
                                            @(r.Type == "chat" ? "Ask" : "Agent")
                                        </span>
                                    </div>
                                    <p class="text-sm text-muted-foreground truncate">@Truncate(r.MatchingText, 100)</p>
                                    <div class="flex items-center gap-3 mt-1.5 text-xs text-muted-foreground/70">
                                        <span>@DateTimeOffset.FromUnixTimeMilliseconds(r.Timestamp).LocalDateTime.ToString("MMM d, yyyy")</span>
                                    </div>
                                </div>
                            </button>
                        }
                    </div>
                }
            </div>

            <div class="flex items-center justify-between border-t border-border px-4 py-2 bg-muted/30 text-xs text-muted-foreground">
                <span>↑↓ Navigate · Enter Open · Esc Close</span>
            </div>
        </div>
    </div>
}

@implements IDisposable

@code {
    private bool _open;
    private string _query = "";
    private string _filter = "all";
    private List<SearchResult> _results = new();
    private bool _loading;
    private int _selectedIndex;
    private System.Timers.Timer? _debounce;

    private void Open() => _open = true;
    private void Close() { _open = false; _query = ""; _results.Clear(); }

    public void Dispose()
    {
        _debounce?.Stop();
        _debounce?.Dispose();
    }

    private async Task OnQueryChanged()
    {
        _debounce?.Stop();
        _debounce?.Dispose();
        if (string.IsNullOrWhiteSpace(_query)) { _results.Clear(); return; }

        _debounce = new System.Timers.Timer(300);
        _debounce.Elapsed += async (_, _) =>
        {
            _debounce?.Stop();
            await InvokeAsync(async () =>
            {
                _loading = true;
                StateHasChanged();
                _results = await SearchSvc.SearchAsync(_query, _filter);
                _selectedIndex = 0;
                _loading = false;
                StateHasChanged();
            });
        };
        _debounce.AutoReset = false;
        _debounce.Start();
    }

    private async Task SetFilter(string f) { _filter = f; await OnQueryChanged(); }

    private void OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "ArrowDown") _selectedIndex = Math.Min(_selectedIndex + 1, _results.Count - 1);
        else if (e.Key == "ArrowUp") _selectedIndex = Math.Max(_selectedIndex - 1, 0);
        else if (e.Key == "Enter" && _results.Count > _selectedIndex) NavigateTo(_results[_selectedIndex]);
        else if (e.Key == "Escape") Close();
    }

    private void NavigateTo(SearchResult r)
    {
        Close();
        Nav.NavigateTo($"/workspace/{r.WorkspaceId}?tab={r.ChatId}&type={r.Type}");
    }

    private static string Truncate(string text, int max) =>
        text.Length <= max ? text : text[..max] + "...";
}
